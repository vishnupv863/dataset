# ==========================================================================
# FastAPI / Python Project Gitignore
# ==========================================================================

# Virtual Environments
.venv/
venv/
ENV/
env/
# Custom local environments used by poetry, pipenv, etc.
.pyenv/
.pipenv/

# Environment Variables & Secrets (CRITICAL: Never commit these!)
.env
.env.*
!.env.example
secrets.json

# Python bytecode / compilation artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
htmlcov/
.toml

# IDEs and Text Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Testing, Coverage, and Linting outputs
.pytest_cache/
.coverage
.coverage.*
nosetests.xml
coverage.xml
.mypy_cache/
.ruff_cache/
.black

# OS generated files
Thumbs.db
Ehthumbs.db
Desktop.ini
.DS_Store

# Temporary / Build directories
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Database files (if using local SQLite for development)
*.db
*.sqlite3